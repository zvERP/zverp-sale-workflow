<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_matricula" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.matricula</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="matricula_ids" context="{'default_partner_id': id}">
                    <tree editable="bottom">
                        <field name="name" />
                        <field name="brand_model" />
                    </tree>
                    <form>
                        <group>
                            <field name="name" />
                            <field name="brand_model" />
                        </group>
                    </form>
                </field>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search_inherit_matricula" model="ir.ui.view">
        <field name="name">res.partner.search.inherit.matricula</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter" />
        <field name="arch" type="xml">
            <search>
                <field name="matricula_ids" string="License Plate" />
            </search>
        </field>
    </record>
</odoo>
