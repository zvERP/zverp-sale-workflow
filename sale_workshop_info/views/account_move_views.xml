<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_workshop_info" model="ir.ui.view">
        <field name="name">account.move.form.workshop.info</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="before">
                <group string="Workshop data">
                    <field name="is_workshop_quote" />
                    <group attrs="{'invisible': [('is_workshop_quote', '=', False)]}">
                        <field name="workshop_brand_model" />
                        <field name="workshop_plate" />
                        <field name="workshop_km" />
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
